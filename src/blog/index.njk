---
layout: layouts/base.njk
title: Blog
description: Articles, guides, and industry updates for property inspectors.
---
<section class="section-block">
  <div class="container">
    <span class="section-label">Blog</span>
    <h1>Articles &amp; Guides</h1>
    <div class="card-grid">
      {%- for post in collections.posts %}
      <article class="card">
        <span class="card__type">Blog</span>
        <h3 class="card__title"><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
        <time class="card__date" datetime="{{ post.date | isoDate }}">{{ post.date | readableDate }}</time>
        <p class="card__excerpt">{{ post.data.description | truncate(120) }}</p>
      </article>
      {%- endfor %}
    </div>
  </div>
</section>
