---
layout: layouts/base.njk
title: Home
---

{# ── Hero ── #}
<section class="hero">
  <div class="container hero__inner">
    <div class="hero__content">
      <span class="hero__eyebrow">The Inspector's Reference</span>
      <h1 class="hero__heading">Everything you need to know about property inspection</h1>
      <p class="hero__accent"><em>Free. Forever.</em></p>
      <p class="hero__sub">A community-driven knowledge base covering standards, systems, defects, and business practices for residential and commercial inspectors.</p>
      <div class="hero__actions">
        <a href="/wiki/" class="btn btn--primary">Browse the Wiki</a>
        <a href="/blog/" class="btn btn--ghost">Read the Blog</a>
      </div>
    </div>
    <div class="hero__stats">
      {% stat "6", "Chapters" %}
      {% stat "12", "Topics" %}
      {% stat "Free", "Always" %}
      {% stat "CC", "Licensed" %}
    </div>
  </div>
</section>

{# ── Two-Path Cards ── #}
<section class="section-block">
  <div class="container">
    <div class="path-grid">
      <a href="/wiki/sample-article/" class="path-card path-card--green">
        <span class="section-label">New to inspecting?</span>
        <h2 class="path-card__title">Start Here</h2>
        <p>Learn the fundamentals of property inspection from the ground up — standards, systems, and reporting.</p>
        <span class="path-card__arrow">&rarr;</span>
      </a>
      <a href="/wiki/" class="path-card path-card--navy">
        <span class="section-label">Already practicing?</span>
        <h2 class="path-card__title">Browse the Wiki</h2>
        <p>Deep-dive into specific systems, defect identification, code references, and advanced techniques.</p>
        <span class="path-card__arrow">&rarr;</span>
      </a>
    </div>
  </div>
</section>

{# ── Latest Blog Posts ── #}
<section class="section-block section-block--alt">
  <div class="container">
    <span class="section-label">From the Blog</span>
    <h2>Latest Articles</h2>
    <div class="card-grid">
      {%- for post in collections.posts | latest(3) %}
      <article class="card">
        <span class="card__type">Blog</span>
        <h3 class="card__title"><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
        <time class="card__date" datetime="{{ post.date | isoDate }}">{{ post.date | readableDate }}</time>
        <p class="card__excerpt">{{ post.data.description | truncate(120) }}</p>
      </article>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── Wiki Topics ── #}
<section class="section-block">
  <div class="container">
    <span class="section-label">Knowledge Base</span>
    <h2>Wiki Topics</h2>
    <div class="topic-table">
      {%- for topic in site.wikiTopics %}
      <div class="topic-table__cell">
        <span class="topic-table__num">{% if loop.index < 10 %}0{% endif %}{{ loop.index }}</span>
        <span class="topic-table__name">{{ topic }}</span>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── Tools (Placeholder) ── #}
<section class="section-block section-block--alt">
  <div class="container">
    <span class="section-label">Inspector Tools</span>
    <h2>Calculators &amp; Checklists</h2>
    <div class="card-grid">
      <article class="card">
        <span class="card__type">Tool</span>
        <h3 class="card__title">Roof Life Calculator</h3>
        <p class="card__excerpt">Estimate remaining roof life based on material, age, and condition.</p>
      </article>
      <article class="card">
        <span class="card__type">Tool</span>
        <h3 class="card__title">Electrical Panel Guide</h3>
        <p class="card__excerpt">Identify panel brands, known defects, and recall status.</p>
      </article>
      <article class="card">
        <span class="card__type">Tool</span>
        <h3 class="card__title">Pre-Inspection Checklist</h3>
        <p class="card__excerpt">Downloadable checklist covering all major systems and components.</p>
      </article>
    </div>
  </div>
</section>

{# ── Contribute CTA ── #}
<section class="contribute-cta">
  <div class="container contribute-cta__inner">
    <div>
      <h2>Help Build the Wiki</h2>
      <p>InspectorWiki is open source and community-driven. Contribute articles, fix errors, or suggest new topics.</p>
    </div>
    <a href="/about/" class="btn btn--primary">Learn How to Contribute</a>
  </div>
</section>
