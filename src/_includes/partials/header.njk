<header class="site-header">
  <div class="container site-header__inner">
    <a href="/" class="site-logo" aria-label="InspectorWiki home">
      <span class="site-logo__mark">IW</span>
      <span class="site-logo__wordmark">InspectorWiki</span>
    </a>
    <nav class="primary-nav" aria-label="Main navigation">
      <ul class="primary-nav__list">
        {%- for item in site.nav %}
        <li>
          <a href="{{ item.url }}"{% if page.url == item.url or (item.url and item.url != '/' and page.url is string and page.url.startsWith(item.url)) %} aria-current="page"{% endif %} class="primary-nav__link">{{ item.label }}</a>
        </li>
        {%- endfor %}
      </ul>
    </nav>
    <a href="/search/" class="site-header__search" aria-label="Search">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    </a>
  </div>
</header>
