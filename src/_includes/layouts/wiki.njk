---
layout: layouts/base.njk
---
<div class="reading-progress" aria-hidden="true"></div>
<div class="section-block">
  <div class="container wiki-layout">
    {% include "partials/wiki-sidebar.njk" %}
    <article class="prose">
      {# ── Breadcrumbs ── #}
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <ol>
          <li><a href="/">Home</a></li>
          <li><a href="/wiki/">Wiki</a></li>
          {%- if topic %}
          <li><span>{{ topic }}</span></li>
          {%- endif %}
          <li><span aria-current="page">{{ title }}</span></li>
        </ol>
      </nav>

      <header>
        <span class="section-label">{{ topic or "General" }}</span>
        <h1>{{ title }}</h1>
        {%- if lastUpdated %}
        <p class="article-meta">Last updated: <time datetime="{{ lastUpdated }}">{{ lastUpdated }}</time></p>
        {%- endif %}
      </header>

      {# ── Article Tools ── #}
      <div class="article-tools">
        <button id="share-copy" class="article-tools__btn" type="button">Copy link</button>
        <a href="mailto:?subject={{ title | urlencode }}&body={{ site.url }}{{ page.url }}" class="article-tools__btn">Email</a>
        <button id="download-btn" class="article-tools__btn" type="button" aria-expanded="false" data-title="{{ title }}" data-url="{{ site.url }}{{ page.url }}" data-date="{{ date | isoDate }}" data-slug="{{ title | slugify }}">Download</button>
      </div>
      <div id="download-panel" class="download-panel" hidden>
        <button id="dl-txt" class="download-panel__btn" type="button">Plain Text (.txt)</button>
        <button id="dl-md" class="download-panel__btn" type="button">Markdown (.md)</button>
      </div>

      {# ── Table of Contents ── #}
      <nav id="toc-nav" class="toc" aria-label="Table of contents"></nav>

      {{ content | safe }}

      {# ── Related Articles ── #}
      {%- set related = [] %}
      {%- for article in collections.wiki %}
        {%- if article.url != page.url and article.data.topic == topic %}
          {%- set related = (related.push(article), related) %}
        {%- endif %}
      {%- endfor %}
      {%- if related.length > 0 %}
      <section class="related-articles">
        <span class="section-label">More on {{ topic }}</span>
        <ul>
          {%- for article in related %}
          <li><a href="{{ article.url }}">{{ article.data.title }}</a></li>
          {%- endfor %}
        </ul>
      </section>
      {%- endif %}

      {# ── Backlinks ── #}
      {%- set backlinks = collections.wiki | backlinksTo(page.url) %}
      {%- if backlinks.length > 0 %}
      <section class="backlinks">
        <span class="section-label">Referenced in</span>
        <ul>
          {%- for item in backlinks %}
          <li><a href="{{ item.url }}">{{ item.data.title }}</a></li>
          {%- endfor %}
        </ul>
      </section>
      {%- endif %}

      {# ── Prev/Next Nav ── #}
      <nav class="step-nav" aria-label="Article navigation">
        {%- set wikiArticles = collections.wiki %}
        {%- set currentIndex = 0 %}
        {%- for article in wikiArticles %}
          {%- if article.url == page.url %}
            {%- set currentIndex = loop.index0 %}
          {%- endif %}
        {%- endfor %}
        {%- if currentIndex > 0 %}
        <a href="{{ wikiArticles[currentIndex - 1].url }}" class="step-nav__btn step-nav__btn--prev">&larr; {{ wikiArticles[currentIndex - 1].data.title }}</a>
        {%- endif %}
        {%- if currentIndex < wikiArticles.length - 1 %}
        <a href="{{ wikiArticles[currentIndex + 1].url }}" class="step-nav__btn step-nav__btn--next">{{ wikiArticles[currentIndex + 1].data.title }} &rarr;</a>
        {%- endif %}
      </nav>
    </article>
  </div>
</div>

{# ── Breadcrumb JSON-LD ── #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "{{ site.url }}/" },
    { "@type": "ListItem", "position": 2, "name": "Wiki", "item": "{{ site.url }}/wiki/" }{% if topic %},
    { "@type": "ListItem", "position": 3, "name": "{{ topic }}", "item": "{{ site.url }}/wiki/" },
    { "@type": "ListItem", "position": 4, "name": "{{ title }}", "item": "{{ site.url }}{{ page.url }}" }{% else %},
    { "@type": "ListItem", "position": 3, "name": "{{ title }}", "item": "{{ site.url }}{{ page.url }}" }{% endif %}
  ]
}
</script>
